# Clay -- LLM brain configuration (template).
#
# Copy this file to .env and fill in your key:   cp .env.example .env
# .env is gitignored, so your key never gets committed.
#
# These settings are only used by the LLM brain (brains/llm_brain_template.py).
# With no key set, the simulation runs on the offline rule-based StubBrain.

# Your Anthropic API key. Get one at https://console.anthropic.com/
# Leave blank to keep using the offline StubBrain.
ANTHROPIC_API_KEY=

# Which Claude model the brain thinks with. claude-haiku-4-5 is fast and cheap,
# which suits a real-time loop that consults the brain often. Swap for a smarter
# (pricier) model like claude-opus-4-8 if you want richer behaviour.
ANTHROPIC_MODEL=claude-haiku-4-5

# Max tokens per decision. One intent is tiny, so this stays small.
LLM_MAX_TOKENS=200
